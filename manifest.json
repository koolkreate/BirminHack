{
    "name": "InstaGuard — AI & Misinfo Detector",
    "description": "Detect AI-generated media and misinformation on Instagram and YouTube using Gemini AI",
    "version": "1.0.0",
    "manifest_version": 3,
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "https://*.instagram.com/*",
        "https://*.cdninstagram.com/*",
        "https://www.youtube.com/*",
        "https://i.ytimg.com/*",
        "https://gen.pollinations.ai/*",
        "https://api.elevenlabs.io/*"
    ],
    "action": {
        "default_icon": "icons/icon128.png",
        "default_popup": "popup/popup.html"
    },
    "background": {
        "service_worker": "src/background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.instagram.com/*",
                "https://www.youtube.com/*"
            ],
            "js": [
                "src/content.js"
            ],
            "css": [
                "src/overlay.css"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://www.instagram.com/*"
            ],
            "js": [
                "src/detector.js"
            ],
            "world": "MAIN",
            "run_at": "document_idle"
        }
    ]
}
